{
  "name": "5ive-connect4-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "run": "npm run build && node dist/main.js",
    "test:localnet": "npm run build && node --test dist/tests/localnet.test.js",
    "test:journey:localnet": "npm run build && node --test dist/tests/user-journey.localnet.test.js",
    "journey:localnet": "npm run build && node dist/journey.localnet.js",
    "gui:localnet": "npm run build && node dist/gui-server.js"
  },
  "dependencies": {
    "@5ive-tech/sdk": "^1.1.7",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.2"
  }
}
